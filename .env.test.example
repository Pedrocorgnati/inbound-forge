# ============================================================
# Inbound Forge — Environment Variables para Testes de Integração (TEMPLATE)
# ============================================================
# Copie este arquivo para .env.test e preencha os valores locais.
# O arquivo .env.test NAO é commitado (ver .gitignore).
# Configure para apontar para um banco PostgreSQL de teste separado.
# ============================================================

NODE_ENV=test

# ─── Database de Teste (OBRIGATÓRIO — banco SEPARADO de dev/produção) ────────
# Use docker compose para criar o banco de teste:
#   docker compose -f docker-compose.test.yml up -d
#
# Ou use o serviço de test do docker-compose.yml (se disponível)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inbound_forge_test
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/inbound_forge_test

# ─── Supabase (usar projeto de teste ou dev, com service role key) ────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-test-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Worker Auth Token (valor de teste — não usar em produção) ────────────────
WORKER_AUTH_TOKEN=test-worker-token-integration-safe

# ─── Redis (Upstash ou local para testes) ────────────────────────────────────
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=test-redis-token

# ─── App URLs ────────────────────────────────────────────────────────────────
# Nota: NEXTAUTH_* removido — projeto usa Supabase Auth
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BLOG_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Inbound Forge Test
PII_ENCRYPTION_KEY=test-pii-key-32-chars-exactly-ok!
INTERNAL_HEALTH_SECRET=test-health-secret

# Claude / Ideogram — não executar geração real em testes
ANTHROPIC_API_KEY=sk-ant-test-DISABLED
IDEOGRAM_API_KEY=test-DISABLED
FAL_API_KEY=test-DISABLED
