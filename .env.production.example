# ============================================================
# Inbound Forge — Environment Variables (Production)
# ============================================================
# Gerado automaticamente por: /env-creation
# Data: 2026-03-26
#
# ⚠️  ATENCAO CRITICA ⚠️
# ═══════════════════════════════════════════════════════════
# ESTE ARQUIVO CONTEM PLACEHOLDERS E NAO DEVE SER COMMITADO
# COM VALORES REAIS EM REPOSITORIO GIT.
#
# USE UM SECRETS MANAGER:
#   - Vercel Environment Variables (dashboard.vercel.com)
#   - Railway Variables (dashboard.railway.app)
#   - AWS Secrets Manager
#   - HashiCorp Vault
#   - Doppler (doppler.com)
#
# NUNCA compartilhe secrets via email, Slack, ou chat.
# ═══════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────
# AMBIENTE
# ────────────────────────────────────────────────────────────
NODE_ENV=production

# ────────────────────────────────────────────────────────────
# APLICACAO NEXT.JS
# Nota: o projeto usa Supabase Auth — NEXTAUTH_* NAO e necessario
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Substitua pelo seu dominio real
NEXT_PUBLIC_APP_URL=https://inbound-forge.vercel.app
NEXT_PUBLIC_BASE_URL=https://inbound-forge.vercel.app
NEXT_PUBLIC_BLOG_BASE_URL=https://inbound-forge.vercel.app
NEXT_PUBLIC_SITE_NAME=Inbound Forge

# ────────────────────────────────────────────────────────────
# SEGURANCA
# ────────────────────────────────────────────────────────────
# ⚠️  PRODUCTION - Gere uma chave unica para producao
# Comando: openssl rand -base64 32
# Usa AES-256-GCM para criptografar Lead.contactInfo
PII_ENCRYPTION_KEY=[PRODUCTION] use-secrets-manager

# ⚠️  PRODUCTION - Gere um token unico para producao
# Usado em Authorization: Bearer <token>
WORKER_AUTH_TOKEN=[PRODUCTION] use-secrets-manager

# ⚠️  PRODUCTION - Gere um secret unico para producao
INTERNAL_HEALTH_SECRET=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# BANCO DE DADOS (Supabase PostgreSQL)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Substitua com sua connection string de producao
# Obter em: https://supabase.com/dashboard > Project Settings > Database > Connection String
DATABASE_URL=[PRODUCTION] postgresql://postgres.prod-ref:password@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Conexao direta para migrations (use secrets manager, nao .env)
DIRECT_URL=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# SUPABASE (Auth + Storage)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Substitua com seus valores reais de producao
NEXT_PUBLIC_SUPABASE_URL=[PRODUCTION] https://your-prod-project.supabase.co

# [PRODUCTION] Anon key de producao (publico, OK em .env)
NEXT_PUBLIC_SUPABASE_ANON_KEY=[PRODUCTION] use-secrets-manager

# ⚠️  PRODUCTION - NUNCA compartilhe esta chave
# Obter em: https://supabase.com/dashboard > Project Settings > API > Service Role Secret
SUPABASE_SERVICE_ROLE_KEY=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# UPSTASH REDIS (Production)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Use database Upstash de producao com replicacao
UPSTASH_REDIS_REST_URL=[PRODUCTION] https://your-prod-id.upstash.io

# ⚠️  PRODUCTION - Use secrets manager
UPSTASH_REDIS_REST_TOKEN=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# CLAUDE API (Anthropic - Production)
# ────────────────────────────────────────────────────────────
# ⚠️  PRODUCTION - Crie uma chave separada para producao
# Obter em: https://console.anthropic.com > API Keys
#
# Recomendacoes:
#   - Crie uma chave especifica para producao
#   - Use um secrets manager (nao .env files)
#   - Configure budget alerts no painel Anthropic
#   - Monitore uso com Sentry/Datadog
ANTHROPIC_API_KEY=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# IMAGE WORKER (Producao)
# ────────────────────────────────────────────────────────────
# ⚠️  PRODUCTION - Use chaves de producao
IDEOGRAM_API_KEY=[PRODUCTION] use-secrets-manager

# ⚠️  PRODUCTION - Use chaves de producao
FAL_API_KEY=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# INSTAGRAM GRAPH API (Production)
# ────────────────────────────────────────────────────────────
# ⚠️  PRODUCTION - Use credenciais de producao
# ATENCAO: Long-lived tokens expiram em 90 dias — renovar regularmente
INSTAGRAM_APP_ID=[PRODUCTION] use-secrets-manager
INSTAGRAM_APP_SECRET=[PRODUCTION] use-secrets-manager
INSTAGRAM_USER_ACCESS_TOKEN=[PRODUCTION] use-secrets-manager
INSTAGRAM_BUSINESS_ACCOUNT_ID=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# POSTHOG (Feature Flags - Production)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Use projeto PostHog de producao
POSTHOG_API_KEY=[PRODUCTION] phc_your-production-key...
POSTHOG_HOST=https://app.posthog.com

# ────────────────────────────────────────────────────────────
# GOOGLE ANALYTICS 4 (Production)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Use Measurement ID de producao
# Obter em: https://analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA4_MEASUREMENT_ID=[PRODUCTION] G-XXXXXXXXXXXXX

# ────────────────────────────────────────────────────────────
# RESEND EMAIL API (Production)
# ────────────────────────────────────────────────────────────
# ⚠️  PRODUCTION - Crie uma chave separada para producao
# Recomendacoes:
#   - Use dominio customizado verificado no Resend
#   - Configure DKIM/SPF para melhores taxas de entrega
#   - Monitore bounce rate e unsubscribes
RESEND_API_KEY=[PRODUCTION] use-secrets-manager

# Email destinatario dos alertas criticos de producao
ALERT_EMAIL_TO=[PRODUCTION] ops-team@your-domain.com

# Email remetente (deve ser dominio verificado no Resend)
ALERT_EMAIL_FROM=[PRODUCTION] alerts@your-domain.com

# ────────────────────────────────────────────────────────────
# SENTRY (Error Tracking - Production)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Use projeto Sentry de producao
# Obter em: https://sentry.io > Projects > Select Project > Settings
SENTRY_DSN=[PRODUCTION] https://key@o123.ingest.sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=[PRODUCTION] https://key@o123.ingest.sentry.io/project-id

# ⚠️  PRODUCTION - Para source maps no CI/CD
SENTRY_AUTH_TOKEN=[PRODUCTION] use-secrets-manager

# ────────────────────────────────────────────────────────────
# BROWSERLESS (Production)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Use instancia Browserless de producao
# Para alta disponibilidade, use cluster ou Browserless Pro
BROWSERLESS_API_KEY=[PRODUCTION] use-secrets-manager
BROWSERLESS_URL=[PRODUCTION] wss://your-prod-instance.browserless.io

# ────────────────────────────────────────────────────────────
# RAILWAY DEPLOYMENT (Production)
# ────────────────────────────────────────────────────────────
# [PRODUCTION] Configure webhook para deploy notifications
RAILWAY_WEBHOOK_URL=[PRODUCTION] https://webhook.railway.app/...

# ────────────────────────────────────────────────────────────
# BLOG (Production)
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_BLOG_BASE_URL=https://inbound-forge.vercel.app

# ════════════════════════════════════════════════════════════
# CHECKLIST PRE-DEPLOY
# ════════════════════════════════════════════════════════════
#
# [ ] PII_ENCRYPTION_KEY — gerar com openssl rand -base64 32
# [ ] WORKER_AUTH_TOKEN — gerar com openssl rand -base64 32
# [ ] INTERNAL_HEALTH_SECRET — gerar com openssl rand -base64 32
#
# [ ] DATABASE_URL — usar Supabase de producao
# [ ] DIRECT_URL — usar connection string direta
# [ ] SUPABASE_SERVICE_ROLE_KEY — chave de producao
#
# [ ] UPSTASH_REDIS_REST_URL/TOKEN — producao com replicacao
#
# [ ] ANTHROPIC_API_KEY — chave de producao separada
# [ ] IDEOGRAM_API_KEY — chave de producao
# [ ] FAL_API_KEY — chave de producao
#
# [ ] INSTAGRAM_* — credenciais verificadas (nao expiradas)
# [ ] RESEND_API_KEY — chave de producao
# [ ] ALERT_EMAIL_TO — configurado com email real
#
# [ ] SENTRY_DSN — projeto Sentry de producao
# [ ] BROWSERLESS_* — instancia de producao
#
# [ ] Usar Vercel Environment Variables / Railway Variables (NAO .env)
# [ ] Todas as variaveis [PRODUCTION] configuradas
# [ ] NENHUMA valor placeholder [PRODUCTION] permanece
#
# ════════════════════════════════════════════════════════════
