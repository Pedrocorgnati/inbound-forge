# Variáveis de ambiente para workers Railway
# Criado por: auto-flow execute (module-1/TASK-3/ST004)
# Copiar para .env ao desenvolver localmente com docker-compose

# Database
DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<project>:<password>@aws-0-region.pooler.supabase.com:5432/postgres

# Redis
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Worker auth (gerar com: openssl rand -hex 32)
WORKER_AUTH_SECRET=

# AI APIs (conforme worker)
REPLICATE_API_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Worker config
WORKER_TYPE=SCRAPING   # SCRAPING | IMAGE | PUBLISHING
PORT=3001
NODE_ENV=development
