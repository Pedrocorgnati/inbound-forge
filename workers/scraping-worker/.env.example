# Scraping Worker — Variáveis de Ambiente
# TASK-0 ST003 / SEC-001: NUNCA commitar valores reais — apenas placeholders
# Copiar para .env e preencher antes de executar

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# ─── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ─── Worker configuração ──────────────────────────────────────────────────────
WORKER_ID=scraping-worker-01
SCRAPING_CRON_SCHEDULE=0 2 * * *
SCRAPING_BATCH_SIZE=10
MAX_CONCURRENT_PAGES=3
PAGE_TIMEOUT_MS=30000

# ─── Next.js App (para callback interno) ─────────────────────────────────────
NEXTJS_INTERNAL_URL=http://localhost:3000
WORKER_AUTH_TOKEN=your-internal-worker-auth-token-here
