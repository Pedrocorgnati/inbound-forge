# Image Worker — Environment Variables
# Copiar para .env para desenvolvimento local

# Database
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/inbound_forge

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=inbound-forge-assets

# Image Generation Providers
IDEOGRAM_API_KEY=       # https://ideogram.ai/api
FAL_API_KEY=            # https://fal.ai/dashboard/keys

# Worker config
IMAGE_WORKER_TIMEOUT_MS=60000
WORKER_AUTH_TOKEN=      # openssl rand -base64 32
