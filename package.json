{
  "name": "inbound-forge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:state-machines": "vitest run src/lib/state-machines/__tests__",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "validate:i18n": "npx ts-node scripts/validate-i18n.ts",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed:test": "SEED_ENV=test prisma db seed",
    "db:seed:prod": "SEED_ENV=production prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:build": "docker build -t inbound-forge:latest .",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "diff": "^8.0.4",
    "isomorphic-dompurify": "^2.36.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.21",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.4",
    "posthog-js": "^1.191.1",
    "posthog-node": "^4.3.2",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.14.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.24.1"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
