{
  "name": "inbound-forge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check && npm run test",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:state-machines": "vitest run src/lib/state-machines/__tests__",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts && vitest run --config vitest.perf.config.ts",
    "validate:i18n": "npx ts-node scripts/validate-i18n.ts",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed:test": "SEED_ENV=test prisma db seed",
    "db:seed:prod": "SEED_ENV=production prisma db seed",
    "db:seed:mvp": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-mvp-pains.ts",
    "db:reset": "prisma migrate reset --force",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:build": "docker build -t inbound-forge:latest .",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset",
    "test:load:smoke": "k6 run --env SCENARIO=smoke tests/load/scenarios/01-health-basic.js",
    "test:load:smoke:all": "for f in tests/load/scenarios/*.js; do k6 run --env SCENARIO=smoke $f; done",
    "test:load": "k6 run tests/load/scenarios/01-health-basic.js",
    "test:load:blog": "k6 run tests/load/scenarios/07-blog-public.js",
    "test:load:stress": "k6 run --env SCENARIO=stress tests/load/scenarios/01-health-basic.js",
    "test:mutation": "stryker run",
    "test:mutation:incremental": "stryker run --incremental",
    "test:mutation:auth": "stryker run --mutate 'src/lib/auth/**/*.ts'",
    "test:mutation:ai": "stryker run --mutate 'src/lib/ai/**/*.ts'",
    "test:mutation:services": "stryker run --mutate 'src/lib/services/**/*.ts'",
    "analyze": "ANALYZE=true npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google-analytics/data": "^5.2.1",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.6",
    "@tanstack/react-query": "^5.100.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "diff": "^8.0.4",
    "isomorphic-dompurify": "^2.36.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.14",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.4",
    "posthog-js": "^1.191.1",
    "posthog-node": "^4.3.2",
    "prisma": "^6.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.14.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "sonner": "^1.7.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.5.4",
    "web-vitals": "^4.2.4",
    "zod": "^3.24.1"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "overrides": {
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@next/bundle-analyzer": "^14.2.21",
    "@playwright/test": "^1.59.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "jest-axe": "^10.0.0",
    "msw": "^2.13.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.1"
  }
}
