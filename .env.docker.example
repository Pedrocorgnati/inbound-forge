# .env.docker.example — Inbound Forge
# Template para .env.docker (sem secrets reais)
# Copiar para .env.docker e preencher com valores reais antes de usar.
#
# docker cp .env.docker.example .env.docker

# ── AMBIENTE ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── APLICAÇÃO ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Inbound Forge (Dev)
NEXT_TELEMETRY_DISABLED=1

# ── SEGURANÇA (gerar com: openssl rand -base64 32) ───────────────────────────
NEXTAUTH_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32
PII_ENCRYPTION_KEY=GENERATE_WITH_OPENSSL_RAND_BASE64_32
WORKER_AUTH_TOKEN=GENERATE_WITH_OPENSSL_RAND_BASE64_32
INTERNAL_HEALTH_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# ── BANCO DE DADOS (Supabase cloud OU postgres local) ────────────────────────
# MODO A — Supabase cloud:
DATABASE_URL=postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASS@HOST:5432/postgres

# MODO B — Local (docker compose up db):
# DATABASE_URL=postgresql://postgres:dev_password@db:5432/inbound_forge_dev
# DIRECT_URL=postgresql://postgres:dev_password@db:5432/inbound_forge_dev

POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=inbound_forge_dev

# ── SUPABASE ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=inbound-forge-assets

# ── UPSTASH REDIS ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_ID.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# ── ANTHROPIC ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY

# ── IMAGE WORKER ──────────────────────────────────────────────────────────────
IDEOGRAM_API_KEY=
FAL_API_KEY=
IMAGE_WORKER_TIMEOUT_MS=60000

# ── INSTAGRAM ────────────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_USER_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── POSTHOG ──────────────────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_YOUR_KEY
POSTHOG_HOST=https://app.posthog.com

# ── GA4 ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-YOUR_ID

# ── RESEND ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_YOUR_KEY
ALERT_EMAIL_TO=dev@example.com
ALERT_EMAIL_FROM=alertas@inbound-forge.app

# ── SENTRY ───────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── BROWSERLESS ──────────────────────────────────────────────────────────────
BROWSERLESS_API_KEY=
BROWSERLESS_URL=wss://chrome.browserless.io

# ── BLOG ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BLOG_BASE_URL=http://localhost:3000

# ── TESTES ───────────────────────────────────────────────────────────────────
E2E_TEST_EMAIL=test-user@example.com
E2E_TEST_PASSWORD=TestPassword123!
TEST_BASE_URL=http://localhost:3000
