# ============================================================
# Inbound Forge — Environment Variables (Template)
# ============================================================
# MODELO PARA DESENVOLVIMENTO
# Copie este arquivo para .env.local e preencha os valores
#
# NUNCA commite .env ou .env.production com valores reais
# ============================================================

# Ambiente
NODE_ENV=development

# App URLs
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://inbound-forge.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Inbound Forge

# Seguranca (gerar com: openssl rand -base64 32)
NEXTAUTH_SECRET=
PII_ENCRYPTION_KEY=
WORKER_AUTH_TOKEN=
INTERNAL_HEALTH_SECRET=

# Database
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=inbound-forge-assets

# Redis
UPSTASH_REDIS_REST_URL=https://your-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# APIs
ANTHROPIC_API_KEY=sk-ant-
IDEOGRAM_API_KEY=
FAL_API_KEY=

# Instagram (opcional para dev)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_USER_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# PostHog & Analytics
POSTHOG_API_KEY=phc_
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-

# Email & Alerts
RESEND_API_KEY=re_
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=alertas@inbound-forge.app

# Observability
SENTRY_DSN=https://key@o123.ingest.sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://key@o123.ingest.sentry.io/project
SENTRY_AUTH_TOKEN=

# Scraping
BROWSERLESS_API_KEY=
BROWSERLESS_URL=wss://chrome.browserless.io

# Deploy
RAILWAY_WEBHOOK_URL=https://webhook.railway.app/...

# Blog
NEXT_PUBLIC_BLOG_BASE_URL=http://localhost:3000

# Testing
E2E_TEST_EMAIL=test-user@example.com
E2E_TEST_PASSWORD=TestPassword123!
TEST_BASE_URL=http://localhost:3000
DATABASE_URL_TEST=

# Image Worker
IMAGE_WORKER_TIMEOUT_MS=60000
