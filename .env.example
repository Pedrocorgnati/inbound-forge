# ============================================================
# Inbound Forge — Environment Variables (Template)
# ============================================================
# MODELO PARA DESENVOLVIMENTO
# Copie este arquivo para .env.local e preencha os valores
#
# NUNCA commite .env ou .env.production com valores reais
# ============================================================

# Ambiente
NODE_ENV=development

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Inbound Forge
NEXT_PUBLIC_BLOG_BASE_URL=http://localhost:3000

# Seguranca (gerar com: openssl rand -base64 32)
# Nota: o projeto usa Supabase Auth — NEXTAUTH_* NAO e usado
PII_ENCRYPTION_KEY=
WORKER_AUTH_TOKEN=
# WORKER_AUTH_SECRET: autentica workers ENTRANTES (webhooks do image-worker)
# Diferente de WORKER_AUTH_TOKEN que autentica chamadas SAINTES para workers
# Gerar com: openssl rand -base64 32
WORKER_AUTH_SECRET=
INTERNAL_HEALTH_SECRET=

# Database
# pgbouncer=true: usa transaction mode do Supabase pooler (necessário para serverless)
# connection_limit=5: limita conexões por instância Vercel (pgBouncer tem pool de 20-25)
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5
# DIRECT_URL: sem pgbouncer — usado pelo Prisma para migrations (prisma migrate deploy)
DIRECT_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres

# Supabase
# SUPABASE_HOSTNAME: hostname exato do projeto (ex: xyzabc.supabase.co) — usado no remotePatterns do next.config.mjs
# Em produção, substitua pelo hostname real para evitar o wildcard genérico *.supabase.co
SUPABASE_HOSTNAME=your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=inbound-forge-assets

# Redis
UPSTASH_REDIS_REST_URL=https://your-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# APIs (OPCIONAIS se CONTENT_GENERATION_MODE=manual — usar Claude Max via web/CLI)
# Para operar sem custo de API, defina CONTENT_GENERATION_MODE=manual
# e use o endpoint POST /api/content/[themeId]/angles/import para importar ângulos
CONTENT_GENERATION_MODE=api
ANTHROPIC_API_KEY=sk-ant-
# IDEOGRAM_API_KEY e FAL_API_KEY: opcionais — usar ChatGPT DALL-E como alternativa
IDEOGRAM_API_KEY=
FAL_API_KEY=

# Instagram (opcional para dev)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_USER_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# PostHog & Analytics
POSTHOG_API_KEY=phc_
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-

# Google Analytics 4 — Data API (analytics server-side)
# GOOGLE_ANALYTICS_PROPERTY_ID: ID da propriedade GA4 (ex: 123456789)
# Encontrar em: GA4 > Admin > Property > Property Details
GOOGLE_ANALYTICS_PROPERTY_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY: JSON completo da service account (base64 ou inline)
# Criar em: Google Cloud Console > IAM > Service Accounts > Keys
# Permissão necessária: Viewer na propriedade GA4
GOOGLE_SERVICE_ACCOUNT_KEY=

# Email & Alerts
RESEND_API_KEY=re_
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=alertas@inbound-forge.app

# Observability
SENTRY_DSN=https://key@o123.ingest.sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://key@o123.ingest.sentry.io/project
SENTRY_AUTH_TOKEN=

# Scraping — Browserless remoto (TASK-11 CL-047, CL-173, CL-192)
# BROWSERLESS_API_KEY: token emitido pelo painel Browserless
# BROWSERLESS_URL: endpoint base (informativo)
# BROWSERLESS_WS_URL: endpoint Playwright completo com token — usado pelo worker.
#   Se NAO definido, o scraping-worker cai em chromium.launch local (dev/CI).
#   Formato: wss://chrome.browserless.io/playwright?token=SEU_TOKEN
BROWSERLESS_API_KEY=
BROWSERLESS_URL=wss://chrome.browserless.io
BROWSERLESS_WS_URL=

# Workers
# WORKER_BASE_URL: URL base do image worker (workers/image-worker) — default http://localhost:3001 em dev
WORKER_BASE_URL=http://localhost:3001

# Deploy
RAILWAY_WEBHOOK_URL=https://webhook.railway.app/...

# Blog
# Testing
E2E_TEST_EMAIL=test-user@example.com
E2E_TEST_PASSWORD=TestPassword123!
TEST_BASE_URL=http://localhost:3000
DATABASE_URL_TEST=

# Image Worker
IMAGE_WORKER_TIMEOUT_MS=60000

# Video Worker — OPCIONAL (descomentado no docker-compose por padrão)
# Alternativa recomendada: ChatGPT (roteiro) + CapCut (produção)
# SHORT_VIDEO_MAKER_URL: URL do container Short Video Maker (Docker: http://short-video-maker:3123)
SHORT_VIDEO_MAKER_URL=http://localhost:3123
# PEXELS_API_KEY: opcional — só necessária se usar short-video-maker
PEXELS_API_KEY=
VIDEO_WORKER_TIMEOUT_MS=300000

# Limites de uso de API por serviço (opcional — sobrescreve defaults do código)
# Valores default: anthropic=1000000 tokens, ideogram=1000 req, flux=500 req, browserless=500 req, instagram=200 calls/h
API_LIMIT_ANTHROPIC=1000000
API_LIMIT_IDEOGRAM=1000
API_LIMIT_FLUX=500
API_LIMIT_BROWSERLESS=500
API_LIMIT_INSTAGRAM=200

# ============================================================
# Cron + Secrets (gerar com: openssl rand -base64 32)
# ============================================================
# CRON_SECRET: valida header Authorization: Bearer em /api/cron/*
CRON_SECRET=
# CSRF_SECRET: chave de assinatura de tokens CSRF
CSRF_SECRET=
# BLOG_PREVIEW_SECRET: permite preview de rascunhos no blog via /api/preview?secret=
BLOG_PREVIEW_SECRET=
# KB_EXPORT_SECRET: autoriza export de knowledge base
KB_EXPORT_SECRET=

# ============================================================
# Budget & Cost Guard
# ============================================================
# LLM_COST_BUDGET_DAILY: teto de gasto diario em USD (guardrail llm-cost-guard)
LLM_COST_BUDGET_DAILY=20
# MONTHLY_BUDGET_BRL: teto mensal em BRL — acima disso workers pausam
MONTHLY_BUDGET_BRL=500

# ============================================================
# Scraping Workers
# ============================================================
# SCRAPING_BATCH_SIZE: quantos leads sao processados por ciclo
SCRAPING_BATCH_SIZE=10
# SCRAPING_CRON_SCHEDULE: cron expression para scrape (ex: "0 */6 * * *")
SCRAPING_CRON_SCHEDULE=0 */6 * * *
# MAX_CONCURRENT_PAGES: paginas Browserless em paralelo por worker
MAX_CONCURRENT_PAGES=3
# PAGE_TIMEOUT_MS: timeout por pagina (default 30s)
PAGE_TIMEOUT_MS=30000

# ============================================================
# Publishing / Feature Flags
# ============================================================
ENABLE_PUBLISHING_WORKER=false
ENABLE_LEARN_TO_RANK=false
# ASOV (Assisted Share of Voice) — bonus de atribuicao por dominio interno
ASOV_BONUS_ENABLED=false
# ASOV_INTERNAL_DOMAINS: lista separada por virgula
ASOV_INTERNAL_DOMAINS=

# ============================================================
# Analytics extras
# ============================================================
# GA4_API_SECRET: Measurement Protocol secret (GA4 Admin > Data Streams > API secrets)
GA4_API_SECRET=

# ============================================================
# Storage / Deploy
# ============================================================
# S3_BUCKET: nome do bucket S3 (fallback quando Supabase Storage indisponivel)
S3_BUCKET=
# RAILWAY_API_TOKEN: token para deploy via GitHub Actions (Railway > Account Settings > Tokens)
RAILWAY_API_TOKEN=

# ============================================================
# OpenAI / Perplexity (fallback LLM)
# ============================================================
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=

# ============================================================
# Cal.com — D09 Lead Capture (scheduling pos-qualificacao)
# ============================================================
# CAL_COM_API_KEY: token Bearer emitido em app.cal.com/settings/developer/api-keys
CAL_COM_API_KEY=
# CAL_COM_WEBHOOK_SECRET: segredo usado para assinar HMAC-SHA256 (header x-cal-signature-256)
# Configurar em app.cal.com/settings/developer/webhooks ao registrar o webhook de booking
CAL_COM_WEBHOOK_SECRET=
# CAL_COM_EVENT_URL: link publico do event type (ex: https://cal.com/username/discovery-30m)
# Usado pelo CTAButton variant=calendar — UTMs sao preservadas via querystring
CAL_COM_EVENT_URL=

# ============================================================
# Worker runtime
# ============================================================
# WORKER_ID: identificador unico do worker (Railway fornece automaticamente)
WORKER_ID=
# PORT: porta HTTP do worker (default 3001)
PORT=3001

# ============================================================
# BetterStack Uptime (opcional) — Intake-Review TASK-9 (CL-OP-005)
# ============================================================
# BETTERSTACK_UPTIME_CHECK_SECRET: opcional; se setado, middleware pode
# whitelistar pings externos usando um header compartilhado. Hoje
# /api/health aceita pings anonimos e reconhece header `X-Monitor: betterstack`
# ou UA `Better Uptime Bot` apenas para emitir `X-Monitor-Ack: 1` no response.
BETTERSTACK_UPTIME_CHECK_SECRET=
