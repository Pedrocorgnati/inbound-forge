# .dockerignore — Inbound Forge

# Dependências
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build
.next
out
dist

# Ambiente e secrets
.env
.env.*
!.env.example
!.env.docker.example

# Git
.git
.gitignore
.gitattributes

# Docs e meta
README.md
CHANGELOG.md
*.md
Dockerfile
docker-compose*.yml
.github
.husky

# Testes
coverage
.nyc_output
*.test.ts
*.spec.ts
__tests__
__mocks__

# Saída do SystemForge (nunca vai para imagem)
output/
.claude/

# TypeScript local
*.tsbuildinfo

# Misc
.DS_Store
Thumbs.db
*.log
.cache
.turbo
