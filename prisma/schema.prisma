// Prisma Schema — Inbound Forge
// Gerado por: /back-end-build
// Stack: Next.js 14+ (App Router) | PostgreSQL (Supabase) | Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  OPERATOR
}

enum EntryStatus {
  DRAFT
  VALIDATED
}

enum ThemeStatus {
  ACTIVE
  DEPRIORITIZED
  REJECTED
}

enum ContentAngle {
  AGGRESSIVE
  CONSULTIVE
  AUTHORIAL
}

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
  PENDING_ART
  ROLLED_BACK
  CANCELLED
}

enum QueueStatus {
  PENDING
  PROCESSING
  PAUSED
  DONE
  FAILED
  CANCELLED
}

enum Channel {
  BLOG
  LINKEDIN
  INSTAGRAM
  TIKTOK        // post-MVP — CL-064
  YOUTUBE_SHORTS // post-MVP — CL-065
}

enum WorkerStatus {
  ACTIVE
  IDLE
  ERROR
}

// TASK-1 ST003: Status do audit log de coleta (LGPD CL-147)
enum ScrapingAuditStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum WorkerType {
  SCRAPING
  IMAGE
  VIDEO
  PUBLISHING
}

// TASK-4 ST001 (CL-TH-010): status de jobs individuais na fila.
enum WorkerJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum ConversionType {
  CONVERSATION
  MEETING
  PROPOSAL
  CALENDAR_BOOKING
}

enum AttributionType {
  FIRST_TOUCH
  ASSISTED_TOUCH
}

enum ArticleStatus {
  DRAFT
  SCHEDULED
  REVIEW
  PUBLISHED
  ARCHIVED
  DELETED
}

enum FunnelStage {
  AWARENESS
  CONSIDERATION
  DECISION
}

enum LeadStatus {
  NEW
  MQL
  SQL
  OPPORTUNITY
  CUSTOMER
  LOST
  LEGAL_HOLD
}

enum LeadLossReason {
  BUDGET
  TIMING
  FIT
  NO_RESPONSE
  COMPETITOR
  OTHER
}

enum ImageType {
  CAROUSEL
  STATIC
  STATIC_LANDSCAPE
  STATIC_PORTRAIT
  VIDEO_COVER
  BEFORE_AFTER
  ERROR_CARD
  SOLUTION_CARD
  BACKSTAGE_CARD
}

enum VideoOrientation {
  PORTRAIT   // 1080x1920 (Reels, TikTok, Shorts)
  LANDSCAPE  // 1920x1080 (YouTube, LinkedIn)
}

enum CTADestination {
  WHATSAPP
  BLOG
  CONTACT_FORM
}

enum ObjectionType {
  PRICE
  TRUST
  TIMING
  NEED
  AUTHORITY
}

// ─── Entidades ───────────────────────────────────────────────────────────────

model Operator {
  id                   String   @id @default(uuid())
  email                String   @unique
  onboardingCompleted  Boolean  @default(false) @map("onboarding_completed")
  preferences          Json?
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations — module-6
  sources          Source[]
  scrapedTexts     ScrapedText[]
  activationEvents ActivationEvent[]

  @@map("operators")
}

// TASK-1 ST001 (CL-031): evento de ativacao disparado uma vez por operator quando
// threshold 5+5 (cases+pains) e atingido no onboarding. Unique(operatorId) garante
// idempotencia mesmo com retries.
model ActivationEvent {
  id           String   @id @default(uuid())
  operatorId   String   @unique @map("operator_id")
  triggeredAt  DateTime @default(now()) @map("triggered_at")
  casesCount   Int      @map("cases_count")
  painsCount   Int      @map("pains_count")
  meta         Json?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([triggeredAt], name: "IDX_activation_events_triggered_at")
  @@map("activation_events")
}

// TASK-4 ST001 (CL-TH-010): jobs individuais da fila (distinto de WorkerHealth
// que registra estado agregado do worker). Popula `/health/jobs`.
model WorkerJob {
  id          String          @id @default(uuid())
  type        String          @db.VarChar(64)
  status      WorkerJobStatus @default(PENDING)
  retryCount  Int             @default(0) @map("retry_count")
  payload     Json?
  error       String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")
  startedAt   DateTime?       @map("started_at")
  completedAt DateTime?       @map("completed_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([status, createdAt], name: "IDX_worker_jobs_status_created")
  @@index([type, status], name: "IDX_worker_jobs_type_status")
  @@map("worker_jobs")
}

model WorkerHealth {
  id            String       @id @default(uuid())
  type          WorkerType
  status        WorkerStatus @default(ACTIVE)
  lastHeartbeat DateTime     @default(now()) @map("last_heartbeat")
  errorMessage  String?      @map("error_message")
  metadata      Json?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@unique([type])
  @@index([type], name: "IDX_worker_healths_type")
  @@map("worker_healths")
}

model CaseLibraryEntry {
  id                    String      @id @default(uuid())
  name                  String      @db.VarChar(255)
  sector                String      @db.VarChar(100)
  systemType            String      @map("system_type") @db.VarChar(100)
  outcome               String      @db.Text
  hasQuantifiableResult Boolean     @default(false) @map("has_quantifiable_result")
  isDraft               Boolean     @default(true) @map("is_draft")
  lastAutosave          DateTime?   @map("last_autosave")
  status                EntryStatus @default(DRAFT)
  sortOrder             Int         @default(0) @map("sort_order")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  // Relations
  solutionPatterns SolutionPattern[]
  themes           Theme[]
  casePains        CasePain[]

  @@index([status], name: "IDX_case_library_status")
  @@map("case_library_entries")
}

model PainLibraryEntry {
  id              String      @id @default(uuid())
  title           String      @db.VarChar(255)
  description     String      @db.Text
  sectors         String[]
  relevanceScore  Float?      @default(50) @map("relevance_score")
  status          EntryStatus @default(DRAFT)
  sortOrder       Int         @default(0) @map("sort_order")
  // Intake Review TASK-2 (CL-029, CL-034): entradas MVP pre-configuradas.
  isDefault       Boolean     @default(false) @map("is_default")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  // Relations
  solutionPatterns SolutionPattern[]
  themes           Theme[]
  casePains        CasePain[]

  @@unique([title], name: "UQ_pain_library_title")
  @@index([status], name: "IDX_pain_library_status")
  @@index([isDefault], name: "IDX_pain_library_is_default")
  @@map("pain_library_entries")
}

model CasePain {
  caseId String           @map("case_id")
  painId String           @map("pain_id")
  case   CaseLibraryEntry @relation(fields: [caseId], references: [id], onDelete: Cascade)
  pain   PainLibraryEntry @relation(fields: [painId], references: [id], onDelete: Cascade)

  @@id([caseId, painId])
  @@map("case_pains")
}

model SolutionPattern {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(255)
  description String   @db.Text
  painId      String   @map("pain_id")
  caseId      String   @map("case_id")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  pain   PainLibraryEntry @relation(fields: [painId], references: [id])
  case   CaseLibraryEntry @relation(fields: [caseId], references: [id])
  themes Theme[]

  @@index([painId], name: "IDX_solution_patterns_pain")
  @@index([caseId], name: "IDX_solution_patterns_case")
  @@map("solution_patterns")
}

model Objection {
  id        String        @id @default(uuid())
  content   String        @db.Text
  type      ObjectionType
  status    EntryStatus   @default(DRAFT)
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("objections")
}

model KnowledgeEntryVersion {
  id            String   @id @default(uuid())
  entryType     String   @map("entry_type") @db.VarChar(20) // case | pain | pattern | objection
  entryId       String   @map("entry_id")
  version       Int
  snapshot      Json
  createdBy     String?  @map("created_by") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  changeSummary String?  @map("change_summary") @db.VarChar(500)

  @@unique([entryType, entryId, version], name: "UQ_kb_versions_entry_version")
  @@index([entryType, entryId], name: "IDX_kb_versions_entry")
  @@map("knowledge_entry_versions")
}

model NicheOpportunity {
  id             String   @id @default(uuid())
  sector         String   @db.VarChar(100)
  painCategory   String   @map("pain_category") @db.VarChar(255)
  potentialScore Float    @map("potential_score")
  isGeoReady     Boolean  @default(false) @map("is_geo_ready")
  // TASK-11 (CL-249): estado do pool: NEW | APPROVED | DISCARDED.
  status         String   @default("NEW") @db.VarChar(20)
  reviewNote     String?  @map("review_note") @db.VarChar(500)
  reviewedAt     DateTime? @map("reviewed_at")
  reviewedBy     String?  @map("reviewed_by") @db.VarChar(255)
  themeId        String?  @map("theme_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  themes Theme[]

  @@index([status, createdAt], name: "IDX_niche_opps_status")
  @@map("niche_opportunities")
}

// ─── Scraping Worker (module-6) ──────────────────────────────────────────────

// TASK-13 ST002 (CL-105): fontes customizadas para Satori (image-pipeline)
model CustomFont {
  id          String   @id @default(cuid())
  operatorId  String   @map("operator_id")
  family      String   @db.VarChar(120)
  weight      Int      @default(400)
  style       String   @default("normal") @db.VarChar(20)
  storagePath String   @map("storage_path") @db.VarChar(512)
  publicUrl   String?  @map("public_url") @db.VarChar(1024)
  fileSize    Int      @map("file_size")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([operatorId, isActive], name: "IDX_custom_fonts_operator_active")
  @@map("custom_fonts")
}

model Source {
  id             String   @id @default(cuid())
  operatorId     String   @map("operator_id")
  name           String   @db.VarChar(255)
  url            String   @db.VarChar(1024)
  isActive       Boolean  @default(true) @map("is_active")
  isProtected    Boolean  @default(false) @map("is_protected")
  selector       String?  @db.VarChar(512)
  crawlFrequency String   @default("daily") @map("crawl_frequency") @db.VarChar(50)
  rateLimitPerMinute Int  @default(60) @map("rate_limit_per_minute")
  lastCrawledAt  DateTime? @map("last_crawled_at")
  // TASK-3 CL-030: marcacao anti-bot em runtime (distinto de isProtected/INT-093)
  antiBotBlocked      Boolean   @default(false) @map("anti_bot_blocked")
  antiBotReason       String?   @map("anti_bot_reason") @db.VarChar(255)
  antiBotBlockedAt    DateTime? @map("anti_bot_blocked_at")
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  operator          Operator            @relation(fields: [operatorId], references: [id])
  scrapedTexts      ScrapedText[]
  scrapingAuditLogs ScrapingAuditLog[]  // TASK-1 ST003

  @@unique([operatorId, url])
  @@index([operatorId, isActive], name: "IDX_sources_operator_active")
  @@index([isActive, antiBotBlocked], name: "IDX_sources_active_antibot")
  @@map("sources")
}

// TASK-1 ST003: Log dedicado de cada evento de coleta (LGPD CL-147)
model ScrapingAuditLog {
  id               String              @id @default(uuid())
  sourceId         String              @map("source_id")
  sourceUrl        String              @map("source_url") @db.VarChar(1024)
  textsCollected   Int                 @map("texts_collected")
  textsClassified  Int                 @map("texts_classified")
  errorsCount      Int                 @default(0) @map("errors_count")
  durationMs       Int                 @map("duration_ms")
  status           ScrapingAuditStatus
  errorMessage     String?             @map("error_message") @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")

  // Relations
  source Source @relation(fields: [sourceId], references: [id])

  @@index([sourceId, createdAt], name: "IDX_scraping_audit_source_created")
  @@index([status, createdAt], name: "IDX_scraping_audit_status_created")
  @@map("scraping_audit_logs")
}

model ScrapedText {
  id                   String   @id @default(cuid())
  operatorId           String   @map("operator_id")
  sourceId             String   @map("source_id")
  rawText              String?  @map("raw_text") @db.Text          // nullable — descartado após pipeline (COMP-006)
  processedText        String?  @map("processed_text") @db.Text   // texto anonimizado
  url                  String   @db.VarChar(1024)
  title                String?  @db.VarChar(512)
  classificationResult Json?    @map("classification_result")
  isPainCandidate      Boolean  @default(false) @map("is_pain_candidate")
  isProcessed          Boolean  @default(false) @map("is_processed")
  piiRemoved           Boolean  @default(false) @map("pii_removed")
  batchId              String?  @map("batch_id") @db.VarChar(128)
  expiresAt            DateTime? @map("expires_at")               // TTL para COMP-004
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  // Relations
  operator Operator @relation(fields: [operatorId], references: [id])
  source   Source   @relation(fields: [sourceId], references: [id])

  @@index([operatorId, isPainCandidate], name: "IDX_scraped_texts_operator_pain")
  @@index([sourceId, createdAt], name: "IDX_scraped_texts_source_created")
  @@index([batchId], name: "IDX_scraped_texts_batch")
  @@map("scraped_texts")
}

model Theme {
  id                 String      @id @default(uuid())
  title              String      @db.VarChar(500)
  opportunityScore   Float       @default(0) @map("opportunity_score")
  status             ThemeStatus @default(ACTIVE)
  rejectionReason    String?     @map("rejection_reason") @db.Text
  rejectedAt         DateTime?   @map("rejected_at")
  rejectedBy         String?     @map("rejected_by") @db.VarChar(20) // "operator" | "system"
  isNew              Boolean     @default(true) @map("is_new")
  painId             String?     @map("pain_id")
  caseId             String?     @map("case_id")
  solutionPatternId  String?     @map("solution_pattern_id")
  nicheOpportunityId String?     @map("niche_opportunity_id")

  // Scoring fields (module-7)
  conversionScore    Int   @default(0) @map("conversion_score") // CX-01: score final 0-100
  painRelevanceScore Int   @default(0) @map("pain_relevance_score") // componente 0-100
  caseStrengthScore  Int   @default(0) @map("case_strength_score") // componente 0-100
  geoMultiplier      Float @default(1.0) @map("geo_multiplier") // 1.0 ou 1.2
  recencyBonus       Float @default(1.0) @map("recency_bonus") // 0.0, 0.5 ou 1.0
  rejectionCount     Int   @default(0) @map("rejection_count") // RN-006: acumula rejeições de ContentPieces
  regenerationCount  Int   @default(0) @map("regeneration_count") // TASK-6 CL-190: quota de regeneracoes por tema
  scoreBreakdown     Json? @map("score_breakdown") // TASK-5 CL-051: breakdown por sinal

  // Intake-Review TASK-7 ST001 (CL-TH-003, CL-TH-016): autoria + soft-delete dedicado.
  // archivedAt eh a unica fonte de verdade para "arquivado"; status mantem workflow.
  createdBy        String?   @map("created_by") @db.VarChar(64)
  archivedAt       DateTime? @map("archived_at")
  lastPublishedAt  DateTime? @map("last_published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  pain             PainLibraryEntry? @relation(fields: [painId], references: [id])
  case             CaseLibraryEntry? @relation(fields: [caseId], references: [id])
  solutionPattern  SolutionPattern?  @relation(fields: [solutionPatternId], references: [id])
  nicheOpportunity NicheOpportunity? @relation(fields: [nicheOpportunityId], references: [id])
  contentPieces    ContentPiece[]
  firstTouchLeads  Lead[]            @relation("firstTouchTheme")
  asovSnapshots    AsovSnapshot[]

  @@index([status, opportunityScore(sort: Desc)], name: "IDX_themes_status_score")
  @@index([conversionScore(sort: Desc)], name: "IDX_themes_conversion_score")
  @@index([isNew], name: "IDX_themes_is_new")
  @@index([archivedAt], name: "IDX_themes_archived_at")
  @@map("themes")
}

model ContentPiece {
  id                 String         @id @default(uuid())
  themeId            String         @map("theme_id")
  baseTitle          String         @map("base_title") @db.VarChar(500)
  painCategory       String         @map("pain_category") @db.VarChar(255)
  targetNiche        String         @map("target_niche") @db.VarChar(255)
  relatedService     String         @map("related_service") @db.VarChar(255)
  funnelStage        FunnelStage    @map("funnel_stage")
  idealFormat        String         @map("ideal_format") @db.VarChar(50)
  recommendedChannel Channel        @map("recommended_channel")
  ctaDestination     CTADestination @map("cta_destination")
  status             ContentStatus  @default(DRAFT)
  selectedAngle      ContentAngle?  @map("selected_angle")
  editedText         String?        @map("edited_text") @db.Text
  generatedImageUrl  String?        @map("generated_image_url") @db.VarChar(512)
  imageJobId         String?        @unique @map("image_job_id")
  videoJobId         String?        @unique @map("video_job_id")
  generatedVideoUrl  String?        @map("generated_video_url") @db.VarChar(512)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  // Relations
  theme         Theme                 @relation(fields: [themeId], references: [id])
  imageJob      ImageJob?             @relation(fields: [imageJobId], references: [id])
  videoJob      VideoJob?             @relation(fields: [videoJobId], references: [id])
  angles        ContentAngleVariant[]
  rejections    ContentRejection[]
  scheduledPost Post?
  blogArticle   BlogArticle?
  versions      ContentPieceVersion[]

  @@index([themeId], name: "IDX_content_pieces_theme")
  @@index([status], name: "IDX_content_pieces_status")
  @@map("content_pieces")
}

// TASK-12 ST001 (CL-076): versioning de copy de ContentPiece + variants
model ContentPieceVersion {
  id               String       @id @default(uuid())
  pieceId          String       @map("piece_id")
  copy             Json         // snapshot campos textuais (editedText, baseTitle, angles editedBody)
  variantSnapshot  Json         @map("variant_snapshot")
  changeSummary    String?      @map("change_summary") @db.VarChar(500)
  createdBy        String?      @map("created_by")
  createdAt        DateTime     @default(now()) @map("created_at")

  piece            ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@index([pieceId, createdAt(sort: Desc)], name: "IDX_content_piece_versions_piece_created")
  @@map("content_piece_versions")
}

model ContentAngleVariant {
  id                String       @id @default(uuid())
  pieceId           String       @map("piece_id")
  angle             ContentAngle
  text              String       @db.Text
  recommendedCTA    String       @map("recommended_cta") @db.Text
  suggestedChannel  Channel      @map("suggested_channel")
  isSelected        Boolean      @default(false) @map("is_selected")
  // Content generation fields (module-8)
  charCount         Int          @default(0) @map("char_count")
  hashtags          String[]     @default([])
  ctaText           String?      @map("cta_text") @db.VarChar(200)
  editedBody        String?      @map("edited_body") @db.Text
  generationVersion Int          @default(1) @map("generation_version")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @default(now()) @updatedAt @map("updated_at")

  // Relations
  piece ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@unique([pieceId, angle, generationVersion], name: "UQ_content_angle_variant_piece_angle_version")
  @@index([pieceId], name: "IDX_content_angle_variants_piece")
  @@map("content_angle_variants")
}

model ContentRejection {
  id        String        @id @default(uuid())
  pieceId   String        @map("piece_id")
  angle     ContentAngle? @map("angle")
  reason    String?       @db.Text
  createdAt DateTime      @default(now()) @map("created_at")

  // Relations
  piece ContentPiece @relation(fields: [pieceId], references: [id], onDelete: Cascade)

  @@map("content_rejections")
}

model ImageJob {
  id             String    @id @default(uuid())
  contentPieceId String?   @map("content_piece_id")
  templateType   ImageType @default(CAROUSEL) @map("template_type")
  templateId     String?   @map("template_id")
  provider       String?   @db.VarChar(20)
  backgroundProvider String? @map("background_provider") @db.VarChar(20)
  backgroundNeedsText Boolean @default(false) @map("background_needs_text")
  status         String    @default("PENDING") @db.VarChar(20)
  prompt         String?   @db.Text
  imageUrl       String?   @map("image_url") @db.VarChar(512)
  backgroundUrl  String?   @map("background_url") @db.VarChar(512)
  outputUrl      String?   @map("output_url") @db.VarChar(512)
  processingMs   Int?      @map("processing_ms")
  retryCount     Int       @default(0) @map("retry_count")
  metadata       Json?
  errorMessage   String?   @map("error_message") @db.Text
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  contentPiece ContentPiece?  @relation
  template     ImageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([status], name: "IDX_image_jobs_status")
  @@index([contentPieceId], name: "IDX_image_jobs_content_piece_id")
  @@map("image_jobs")
}

// ─── Video Generation (Short Video Maker MCP) ────────────────────────────────

model VideoJob {
  id              String           @id @default(uuid())
  orientation     VideoOrientation @default(PORTRAIT)
  provider        String           @default("short-video-maker") @db.VarChar(30)
  status          String           @default("PENDING") @db.VarChar(20)
  externalVideoId String?          @map("external_video_id") @db.VarChar(100)
  scenes          Json             // Array de { text, searchTerms }
  config          Json?            // { paddingBack, music, captionPosition, voice, musicVolume }
  prompt          String?          @db.Text
  outputUrl       String?          @map("output_url") @db.VarChar(512)
  thumbnailUrl    String?          @map("thumbnail_url") @db.VarChar(512)
  durationMs      Int?             @map("duration_ms")
  fileSizeBytes   Int?             @map("file_size_bytes")
  processingMs    Int?             @map("processing_ms")
  retryCount      Int              @default(0) @map("retry_count")
  metadata        Json?
  errorMessage    String?          @map("error_message") @db.Text
  completedAt     DateTime?        @map("completed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations — FK is on ContentPiece.videoJobId (same pattern as ImageJob)
  contentPiece ContentPiece?

  @@index([status], name: "IDX_video_jobs_status")
  @@map("video_jobs")
}

model VisualAsset {
