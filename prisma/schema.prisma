model Lead {
  id                String       @id @default(uuid())
  name              String?      @db.VarChar(255)
  company           String?      @db.VarChar(255)
  contactInfo       String?      @map("contact_info") @db.Text // AES-256 encrypted — COMP-002
  // TASK-3 ST002 (CL-TA-042): hash deterministico de email+phone para anti-duplicata.
  // Nullable durante backfill; unique index evita duplicatas apos backfill.
  contactHash       String?      @unique @map("contact_hash") @db.VarChar(64)
  firstTouchPostId  String       @map("first_touch_post_id")
  firstTouchThemeId String       @map("first_touch_theme_id")
